    /// 从Clash配置提取代理组信息
    pub fn extract_proxy_groups(&self, config: &ClashConfig) -> Result<Vec<ProxyGroup>> {
        let mut groups = Vec::new();

        if let Some(group_list) = &config.proxy_groups {
            for group_config in group_list {
                if let Ok(group) =
                    serde_yaml::from_value::<ProxyGroup>(Value::Mapping(group_config.clone()))
                {
                    groups.push(group);
                }
            }
        }

        Ok(groups)
    }

    /// 从订阅链接解析代理配置
    pub async fn parse_subscription(&self, url: &str) -> Result<Vec<ProxyNodeInfo>> {
        // 下载订阅内容
        let content = self.download_subscription(url).await?;

        // 尝试多种解析方式
        let proxies = self.parse_subscription_content(&content).await?;

        Ok(proxies)
    }

    /// 下载订阅内容
    async fn download_subscription(&self, url: &str) -> Result<String> {
        use reqwest::Client;

        let client = Client::builder()
            .timeout(std::time::Duration::from_secs(30))
            .build()?;

        let response = client
            .get(url)
            .header("User-Agent", "Clash/1.0")
            .send()
            .await?;

        if !response.status().is_success() {
            return Err(anyhow!("订阅请求失败: {}", response.status()));
        }

        let bytes = response.bytes().await?;

        // 尝试Base64解码（订阅内容通常是Base64编码的）
        let content = match String::from_utf8(bytes.to_vec()) {
            Ok(text) => text,
            Err(_) => {
                // 如果不是有效的UTF-8，尝试Base64解码
                let decoded =
                    base64::Engine::decode(&base64::engine::general_purpose::STANDARD, &bytes)
                        .map_err(|e| anyhow!("Base64解码失败: {}", e))?;
                String::from_utf8_lossy(&decoded).to_string()
            }
        };

        Ok(content)
    }

    /// 解析订阅内容
    async fn parse_subscription_content(&self, content: &str) -> Result<Vec<ProxyNodeInfo>> {
        let content = content.trim();

        // 尝试解析为Clash配置
        if let Ok(config) = self.parse_clash_config(content) {
            return self.extract_proxy_nodes(&config);
        }

        // 尝试解析为代理链接列表（每行一个链接）
        let mut proxies = Vec::new();
        for line in content.lines() {
            let line = line.trim();
            if line.is_empty() || line.starts_with('#') {
                continue;
            }

            // 尝试解析为代理链接
            if let Ok(proxy_info) = self.parse_proxy_link(line) {
                proxies.push(proxy_info);
            }
        }

        if !proxies.is_empty() {
            return Ok(proxies);
        }

        Err(anyhow!("无法解析订阅内容"))
    }

    /// 解析代理链接
    fn parse_proxy_link(&self, link: &str) -> Result<ProxyNodeInfo> {
        use url::Url;

        let link = link.trim();

        // 尝试解析为URL
        if let Ok(url) = Url::parse(link) {
            return self.parse_proxy_url(&url);
        }

        // 尝试解析为Base64编码的vmess链接
        if link.starts_with("vmess://") {
            return self.parse_vmess_link(link);
        }

        // 尝试解析为Base64编码的ss链接
        if link.starts_with("ss://") {
            return self.parse_shadowsocks_link(link);
        }

        // 尝试解析为其他格式
        Err(anyhow!("无法解析代理链接: {}", link))
    }

    /// 解析代理URL
    fn parse_proxy_url(&self, url: &Url) -> Result<ProxyNodeInfo> {
        let scheme = url.scheme();
        let host = url.host_str().ok_or_else(|| anyhow!("URL缺少主机"))?;
        let port = url.port().unwrap_or(match scheme {
            "http" => 80,
            "https" => 443,
            "socks5" => 1080,
            "ss" => 8388,
            _ => 0,
        });

        let mut proxy_info = ProxyNodeInfo {
            name: url.fragment().unwrap_or(host).to_string(),
            protocol: scheme.to_string(),
            server: host.to_string(),
            port,
            ..Default::default()
        };

        // 解析认证信息
        if let Some(password) = url.password() {
            proxy_info.password = Some(password.to_string());
        }
        if let Some(username) = url.username() {
            if !username.is_empty() {
                proxy_info.username = Some(username.to_string());
            }
        }

        // 解析查询参数
        for (key, value) in url.query_pairs() {
            match key.as_ref() {
                "cipher" | "method" => proxy_info.cipher = Some(value.to_string()),
                "uuid" | "id" => proxy_info.uuid = Some(value.to_string()),
                "sni" | "servername" => proxy_info.sni = Some(value.to_string()),
                "tls" => proxy_info.tls = Some(value == "true"),
                "network" | "type" => proxy_info.network = Some(value.to_string()),
                _ => {
                    proxy_info
                        .extra_params
                        .insert(key.to_string(), value.to_string());
                }
            }
        }

        Ok(proxy_info)
    }

    /// 解析vmess链接
    fn parse_vmess_link(&self, link: &str) -> Result<ProxyNodeInfo> {
        // 移除vmess://前缀
        let base64_str = link.trim_start_matches("vmess://");

        // Base64解码
        let decoded =
            base64::Engine::decode(&base64::engine::general_purpose::URL_SAFE, base64_str)
                .map_err(|e| anyhow!("Base64解码失败: {}", e))?;

        let json_str = String::from_utf8_lossy(&decoded);

        // 解析JSON配置
        let config: HashMap<String, Value> =
            serde_json::from_str(&json_str).map_err(|e| anyhow!("JSON解析失败: {}", e))?;

        // 转换为代理配置
        let mut proxy_config = HashMap::new();
        proxy_config.insert("type".to_string(), Value::String("vmess".to_string()));

        // 映射字段
        if let Some(ps) = config.get("ps") {
            proxy_config.insert(
                "name".to_string(),
                Value::String(ps.as_str().unwrap_or("").to_string()),
            );
        }
        if let Some(add) = config.get("add") {
            proxy_config.insert(
                "server".to_string(),
                Value::String(add.as_str().unwrap_or("").to_string()),
            );
        }
        if let Some(port) = config.get("port") {
            if let Some(port_num) = port.as_u64() {
                proxy_config.insert("port".to_string(), Value::Number(port_num.into()));
            }
        }
        if let Some(id) = config.get("id") {
            proxy_config.insert(
                "uuid".to_string(),
                Value::String(id.as_str().unwrap_or("").to_string()),
            );
        }
        if let Some(aid) = config.get("aid") {
            proxy_config.insert(
                "alterId".to_string(),
                Value::Number(aid.as_u64().unwrap_or(0).into()),
            );
        }
        if let Some(cipher) = config.get("type") {
            proxy_config.insert(
                "cipher".to_string(),
                Value::String(cipher.as_str().unwrap_or("auto").to_string()),
            );
        }
        if let Some(net) = config.get("net") {
            proxy_config.insert(
                "network".to_string(),
                Value::String(net.as_str().unwrap_or("").to_string()),
            );
        }
        if let Some(tls) = config.get("tls") {
            proxy_config.insert(
                "tls".to_string(),
                Value::String(tls.as_str().unwrap_or("").to_string()),
            );
        }
        if let Some(sni) = config.get("sni") {
            proxy_config.insert(
                "sni".to_string(),
                Value::String(sni.as_str().unwrap_or("").to_string()),
            );
        }

        // 解析代理配置
        self.parse_proxy_config(&proxy_config)
            .ok_or_else(|| anyhow!("无法解析vmess配置"))
    }

    /// 解析shadowsocks链接
    fn parse_shadowsocks_link(&self, link: &str) -> Result<ProxyNodeInfo> {
        // 移除ss://前缀
        let url_str = link.trim_start_matches("ss://");

        // 解析URL
        let url =
            Url::parse(&format!("ss://{}", url_str)).map_err(|e| anyhow!("URL解析失败: {}", e))?;

        self.parse_proxy_url(&url)
    }

    /// 生成Clash配置
    pub fn generate_clash_config(
        &self,
        proxies: &[ProxyNodeInfo],
        groups: Option<&[ProxyGroup]>,
    ) -> Result<String> {
        let mut config = HashMap::new();

        // 添加代理配置
        let proxy_configs: Vec<HashMap<String, Value>> = proxies
            .iter()
            .filter_map(|proxy| self.generate_proxy_config(proxy))
            .collect();

        if !proxy_configs.is_empty() {
            config.insert(
                "proxies".to_string(),
                Value::Sequence(proxy_configs.into_iter().map(Value::Mapping).collect()),
            );
        }

        // 添加代理组配置
        if let Some(groups) = groups {
            let group_configs: Vec<HashMap<String, Value>> = groups
                .iter()
                .map(|group| self.generate_group_config(group))
                .collect();

            if !group_configs.is_empty() {
                config.insert(
                    "proxy-groups".to_string(),
                    Value::Sequence(group_configs.into_iter().map(Value::Mapping).collect()),
                );
            }
        }

        // 添加基本配置
        config.insert("port".to_string(), Value::Number(7890.into()));
        config.insert("socks-port".to_string(), Value::Number(7891.into()));
        config.insert("mode".to_string(), Value::String("rule".to_string()));
        config.insert("log-level".to_string(), Value::String("info".to_string()));

        // 转换为YAML
        let yaml = serde_yaml::to_string(&config).map_err(|e| anyhow!("YAML生成失败: {}", e))?;

        Ok(yaml)
    }

    /// 生成代理配置
    fn generate_proxy_config(&self, proxy: &ProxyNodeInfo) -> Option<HashMap<String, Value>> {
        let mut config = HashMap::new();

        config.insert("name".to_string(), Value::String(proxy.name.clone()));
        config.insert("type".to_string(), Value::String(proxy.protocol.clone()));
        config.insert("server".to_string(), Value::String(proxy.server.clone()));
        config.insert("port".to_string(), Value::Number(proxy.port.into()));

        // 根据协议类型添加特定字段
        match proxy.protocol.to_lowercase().as_str() {
            "ss" | "shadowsocks" => {
                if let Some(cipher) = &proxy.cipher {
                    config.insert("cipher".to_string(), Value::String(cipher.clone()));
                }
                if let Some(password) = &proxy.password {
                    config.insert("password".to_string(), Value::String(password.clone()));
                }
            }
            "vmess" => {
                if let Some(uuid) = &proxy.uuid {
                    config.insert("uuid".to_string(), Value::String(uuid.clone()));
                }
                if let Some(cipher) = &proxy.cipher {
                    config.insert("cipher".to_string(), Value::String(cipher.clone()));
                }
                if let Some(tls) = proxy.tls {
                    config.insert("tls".to_string(), Value::Bool(tls));
                }
                if let Some(sni) = &proxy.sni {
                    config.insert("sni".to_string(), Value::String(sni.clone()));
                }
                if let Some(network) = &proxy.network {
                    config.insert("network".to_string(), Value::String(network.clone()));
                }
            }
            "trojan" => {
                if let Some(password) = &proxy.password {
                    config.insert("password".to_string(), Value::String(password.clone()));
                }
                if let Some(tls) = proxy.tls {
                    config.insert("tls".to_string(), Value::Bool(tls));
                }
                if let Some(sni) = &proxy.sni {
                    config.insert("sni".to_string(), Value::String(sni.clone()));
                }
            }
            "http" | "https" => {
                if let Some(username) = &proxy.username {
                    config.insert("username".to_string(), Value::String(username.clone()));
                }
                if let Some(password) = &proxy.password {
                    config.insert("password".to_string(), Value::String(password.clone()));
                }
                config.insert("tls".to_string(), Value::Bool(proxy.protocol == "https"));
            }
            "socks5" => {
                if let Some(username) = &proxy.username {
                    config.insert("username".to_string(), Value::String(username.clone()));
                }
                if let Some(password) = &proxy.password {
                    config.insert("password".to_string(), Value::String(password.clone()));
                }
            }
            _ => {
                // 通用字段
                if let Some(password) = &proxy.password {
                    config.insert("password".to_string(), Value::String(password.clone()));
                }
                if let Some(uuid) = &proxy.uuid {
                    config.insert("uuid".to_string(), Value::String(uuid.clone()));
                }
                if let Some(cipher) = &proxy.cipher {
                    config.insert("cipher".to_string(), Value::String(cipher.clone()));
                }
                if let Some(tls) = proxy.tls {
                    config.insert("tls".to_string(), Value::Bool(tls));
                }
                if let Some(sni) = &proxy.sni {
                    config.insert("sni".to_string(), Value::String(sni.clone()));
                }
            }
        }

        // 添加UDP支持
        if let Some(udp) = proxy.extra_params.get("udp") {
            if let Ok(udp_bool) = udp.parse::<bool>() {
                config.insert("udp".to_string(), Value::Bool(udp_bool));
            }
        }

        Some(config)
    }

    /// 生成代理组配置
    fn generate_group_config(&self, group: &ProxyGroup) -> HashMap<String, Value> {
        let mut config = HashMap::new();

        config.insert("name".to_string(), Value::String(group.name.clone()));

        let type_str = match &group.group_type {
            ProxyGroupType::Select => "select",
            ProxyGroupType::UrlTest => "url-test",
            ProxyGroupType::Fallback => "fallback",
            ProxyGroupType::LoadBalance => "load-balance",
            ProxyGroupType::Relay => "relay",
            ProxyGroupType::Other(other) => other.as_str(),
        };
        config.insert("type".to_string(), Value::String(type_str.to_string()));

        config.insert(
            "proxies".to_string(),
            Value::Sequence(
                group
                    .proxies
                    .iter()
                    .map(|p| Value::String(p.clone()))
                    .collect(),
            ),
        );

        if let Some(url) = &group.url {
            config.insert("url".to_string(), Value::String(url.clone()));
        }

        if let Some(interval) = group.interval {
            config.insert("interval".to_string(), Value::Number(interval.into()));
        }

        if let Some(strategy) = &group.strategy {
            config.insert("strategy".to_string(), Value::String(strategy.clone()));
        }

        if let Some(use_list) = &group.r#use {
            config.insert(
                "use".to_string(),
                Value::Sequence(use_list.iter().map(|u| Value::String(u.clone())).collect()),
            );
        }

        config
    }
}
